# ==============================================================================
# Toko-rs Configuration (Environment Variables)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL is the primary database (default feature). SQLite is an optional
# compile-time backend (--features sqlite --no-default-features).
#
# PostgreSQL (default):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/toko
#
# SQLite (requires: cargo build --features sqlite --no-default-features):
# DATABASE_URL=sqlite:toko.db
#
# In-memory SQLite (for testing):
# DATABASE_URL=sqlite::memory:

# ------------------------------------------------------------------------------
# 2. Server Configuration
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=3000

# ------------------------------------------------------------------------------
# 3. Observability & Logging
# ------------------------------------------------------------------------------
RUST_LOG=toko_rs=debug,tower_http=debug,sqlx=info

# ------------------------------------------------------------------------------
# 4. Currency Configuration
# ------------------------------------------------------------------------------
# Default currency code (ISO 4217, lowercase). Used as the default for new
# carts and payment records. IDR = Indonesian Rupiah.
DEFAULT_CURRENCY_CODE=idr

# ------------------------------------------------------------------------------
# 5. CORS Configuration
# ------------------------------------------------------------------------------
# Comma-separated allowed origins. Default: "*" (allow all).
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000
