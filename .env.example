# ==============================================================================
# Toko-rs Configuration (Environment Variables)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL is the primary database (matching Medusa). SQLite is used for
# local development and in-memory integration tests.
#
# Examples:
#   Local (SQLite) : sqlite://toko.db?mode=rwc
#   Prod (Postgres): postgres://postgres:password@localhost/toko
DATABASE_URL=sqlite://toko.db?mode=rwc

# ------------------------------------------------------------------------------
# 2. Server Configuration
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=3000

# ------------------------------------------------------------------------------
# 3. Observability & Logging
# ------------------------------------------------------------------------------
RUST_LOG=toko_rs=debug,tower_http=debug,sqlx=info

# ------------------------------------------------------------------------------
# 4. Currency Configuration
# ------------------------------------------------------------------------------
# Default currency code (ISO 4217, lowercase). Used as the default for new
# carts and payment records. IDR = Indonesian Rupiah.
DEFAULT_CURRENCY_CODE=idr
